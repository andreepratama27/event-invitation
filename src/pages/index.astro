---
import '../styles/global.css';
import OpeningGate from '../components/OpeningGate.astro';
import HeroSection from '../components/HeroSection.astro';
import InvitationSection from '../components/InvitationSection.astro';
import NameMeanings from '../components/NameMeanings.astro';
import GallerySection from '../components/GallerySection.astro';
import DirectionSection from '../components/DirectionSection.astro';
import GuestbookSection from '../components/GuestbookSection.astro';
import { event } from '../config/event';

const { site, baby, type: eventType, dateLabel } = event;
---

<html lang={site.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Primary -->
    <title>{site.ogTitle}</title>
    <meta name="description" content={site.ogDescription} />
    <link rel="canonical" href={site.url} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={site.url} />
    <meta property="og:title" content={site.ogTitle} />
    <meta property="og:description" content={site.ogDescription} />
    <meta property="og:image" content={site.ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`Undangan ${eventType} ${baby.fullName} – ${dateLabel}`} />
    <meta property="og:locale" content={site.locale} />
    <meta property="og:site_name" content={site.ogTitle} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={site.ogTitle} />
    <meta name="twitter:description" content={site.ogDescription} />
    <meta name="twitter:image" content={site.ogImage} />
    <meta name="twitter:image:alt" content={`Undangan ${eventType} ${baby.fullName} – ${dateLabel}`} />

    <!-- WhatsApp / iMessage use og: tags above, no extra tags needed -->

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
  </head>
  <body>
    <OpeningGate />
    <main>
      <HeroSection />
      <InvitationSection />
      <NameMeanings />
      <GallerySection />
      <DirectionSection />
      <GuestbookSection />
    </main>
  </body>
</html>

<!-- Dynamic XP Bar — progress from today toward event day -->
<script define:vars={{ eventDatetimeISO: event.datetimeISO }}>
  const today = new Date();
  today.setHours(0, 0, 0, 0);
  const xpStart = today;
  const xpEnd   = new Date(eventDatetimeISO);
  const now     = Date.now();
  const total   = xpEnd.getTime() - xpStart.getTime();
  const elapsed = Math.min(Math.max(now - xpStart.getTime(), 0), total);
  const pct     = Math.round((elapsed / total) * 100);

  const fillEl = document.getElementById('xp-fill');
  const textEl = document.getElementById('xp-text');
  if (fillEl) requestAnimationFrame(() => { fillEl.style.width = pct + '%'; });
  if (textEl) textEl.textContent = pct + ' / 100 XP';
</script>

<!-- Countdown Timer -->
<script define:vars={{ eventDatetimeISO: event.datetimeISO }}>
  const target = new Date(eventDatetimeISO);

  function pad(n) {
    return String(n).padStart(2, '0');
  }

  function tick() {
    const diff = target.getTime() - Date.now();

    const hariEl  = document.getElementById('cd-hari');
    const jamEl   = document.getElementById('cd-jam');
    const menitEl = document.getElementById('cd-menit');
    const detikEl = document.getElementById('cd-detik');
    const doneEl  = document.getElementById('cd-done');
    const boxesEl = document.getElementById('cd-boxes');

    if (!hariEl || !jamEl || !menitEl || !detikEl) return;

    if (diff <= 0) {
      if (boxesEl) boxesEl.style.display = 'none';
      if (doneEl)  doneEl.style.display  = 'block';
      return;
    }

    const totalSec = Math.floor(diff / 1000);
    const hari  = Math.floor(totalSec / 86400);
    const jam   = Math.floor((totalSec % 86400) / 3600);
    const menit = Math.floor((totalSec % 3600) / 60);
    const detik = totalSec % 60;

    const prevDetik = detikEl.textContent;
    hariEl.textContent  = pad(hari);
    jamEl.textContent   = pad(jam);
    menitEl.textContent = pad(menit);
    detikEl.textContent = pad(detik);

    if (prevDetik !== detikEl.textContent) {
      detikEl.style.animation = 'none';
      void detikEl.offsetHeight;
      detikEl.style.animation = 'count-pop 0.3s ease-out';
    }
  }

  tick();
  setInterval(tick, 1000);
</script>

<!-- Scroll Reveal -->
<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12 }
  );

  document.querySelectorAll('.animate-on-scroll').forEach((el) => {
    observer.observe(el);
  });
</script>
