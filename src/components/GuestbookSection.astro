---
---

<section class="section-wrapper guestbook-section">
  <div class="section-inner">
    <div class="section-label animate-on-scroll">GUESTBOOK · UCAPAN</div>

    <h2 class="section-heading animate-on-scroll">
      Tulis Ucapanmu
    </h2>
    <p class="section-sub animate-on-scroll">
      Doa dan harapanmu adalah hadiah terindah untuk Emir 💜
    </p>

    <div class="board-card clay-purple animate-on-scroll">
      <!-- Card header -->
      <div class="card-header">
        <span class="card-header-icon">⭐</span>
        <div>
          <p class="card-header-pre">Buku Tamu</p>
          <p class="card-header-title">Kirim Ucapan & Doa</p>
        </div>
      </div>

      <!-- Form -->
      <div class="card-body">
        <form id="guestbook-form" class="guestbook-form" novalidate>
          <div class="form-group">
            <label class="form-label" for="guest-name">
              👤 Nama Kamu
            </label>
            <input
              id="guest-name"
              class="form-input"
              type="text"
              name="name"
              required
              minlength="2"
              placeholder="Tulis namamu di sini..."
              autocomplete="name"
            />
          </div>

          <div class="form-group">
            <label class="form-label" for="guest-message">
              💬 Ucapan & Doa
            </label>
            <textarea
              id="guest-message"
              class="form-input form-textarea"
              name="message"
              required
              minlength="5"
              rows="4"
              placeholder="Tuliskan doa dan harapanmu untuk Emir Ayden Mateen..."
            ></textarea>
          </div>

          <div id="guestbook-error" class="form-error" hidden></div>

          <button type="submit" class="clay-btn clay-btn--green submit-btn" id="guestbook-submit-btn">
            ⭐ Kirim Ucapan
          </button>
        </form>

        <!-- Thank-you state (hidden initially) -->
        <div id="guestbook-success" class="success-state" hidden>
          <div class="success-icon">🎉</div>
          <h3 class="success-title">Terima kasih!</h3>
          <p class="success-text">Doa dan ucapanmu sudah kami terima. Semoga Allah SWT membalas kebaikanmu. 🤲</p>
          <div class="success-stars" aria-hidden="true">⭐ ⭐ ⭐</div>
          <button type="button" class="clay-btn clay-btn--green write-again-btn" id="guestbook-write-again">
            ✏️ Tulis Lagi
          </button>
        </div>
      </div>
    </div>

    <!-- Messages list -->
    <div class="messages-section animate-on-scroll">
      <div class="messages-header">
        <span class="messages-header-icon">💌</span>
        <h3 class="messages-header-title">Ucapan & Doa dari Tamu</h3>
      </div>

      <div id="guestbook-loading" class="messages-loading">
        <span class="loading-spinner">⏳</span> Memuat ucapan...
      </div>

      <div id="guestbook-empty" class="messages-empty" hidden>
        <p>Belum ada ucapan. Jadilah yang pertama! 🌟</p>
      </div>

      <div id="guestbook-messages" class="messages-list"></div>
    </div>

    <!-- Footer note -->
    <div class="footer-blessing animate-on-scroll">
      <p>Jazakumullahu Khairan Katsiran</p>
      <p class="footer-parents">Andre Pratama &amp; Syaras Saryang Putri</p>
      <p class="footer-small">beserta keluarga besar 🌙</p>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var form = document.getElementById('guestbook-form');
    var success = document.getElementById('guestbook-success');
    var errorEl = document.getElementById('guestbook-error');
    var submitBtn = document.getElementById('guestbook-submit-btn');
    var writeAgainBtn = document.getElementById('guestbook-write-again');
    var messagesContainer = document.getElementById('guestbook-messages');
    var loadingEl = document.getElementById('guestbook-loading');
    var emptyEl = document.getElementById('guestbook-empty');

    function formatDate(dateStr) {
      var d = new Date(dateStr);
      return d.toLocaleDateString('id-ID', {
        day: 'numeric', month: 'long', year: 'numeric',
        hour: '2-digit', minute: '2-digit'
      });
    }

    function createMessageCard(entry) {
      var card = document.createElement('div');
      card.className = 'message-card';
      card.innerHTML =
        '<div class="message-card-header">' +
          '<span class="message-avatar">👤</span>' +
          '<div>' +
            '<p class="message-name">' + escapeHtml(entry.name) + '</p>' +
            '<p class="message-date">' + formatDate(entry.created_at) + '</p>' +
          '</div>' +
        '</div>' +
        '<p class="message-text">' + escapeHtml(entry.message) + '</p>';
      return card;
    }

    function escapeHtml(str) {
      var div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    function loadMessages() {
      fetch('/api/guestbook')
        .then(function (res) { return res.json(); })
        .then(function (result) {
          if (loadingEl) loadingEl.hidden = true;

          if (!result.ok || !result.data || result.data.length === 0) {
            if (emptyEl) emptyEl.hidden = false;
            return;
          }

          if (emptyEl) emptyEl.hidden = true;
          if (messagesContainer) {
            messagesContainer.innerHTML = '';
            result.data.forEach(function (entry) {
              messagesContainer.appendChild(createMessageCard(entry));
            });
          }
        })
        .catch(function () {
          if (loadingEl) loadingEl.hidden = true;
          if (emptyEl) emptyEl.hidden = false;
        });
    }

    // Load messages on page load
    loadMessages();

    if (form && success) {
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        if (errorEl) errorEl.hidden = true;

        var nameEl = document.getElementById('guest-name');
        var msgEl = document.getElementById('guest-message');
        if (!nameEl || !msgEl) return;

        var name = nameEl.value.trim();
        var msg = msgEl.value.trim();

        if (!name || name.length < 2) { nameEl.focus(); return; }
        if (!msg || msg.length < 5) { msgEl.focus(); return; }

        // Disable button while submitting
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = '⏳ Mengirim...';
        }

        fetch('/api/guestbook', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name: name, message: msg })
        })
          .then(function (res) { return res.json(); })
          .then(function (result) {
            if (!result.ok) {
              if (errorEl) {
                errorEl.textContent = result.error || 'Gagal mengirim ucapan.';
                errorEl.hidden = false;
              }
              if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.textContent = '⭐ Kirim Ucapan';
              }
              return;
            }

            // Show success
            form.style.opacity = '0';
            form.style.transform = 'scale(0.95)';
            setTimeout(function () {
              form.hidden = true;
              success.hidden = false;
              success.style.opacity = '0';
              success.style.transform = 'scale(0.8)';
              void success.offsetHeight;
              success.style.transition = 'opacity 0.5s ease, transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1)';
              success.style.opacity = '1';
              success.style.transform = 'scale(1)';
            }, 300);

            // Prepend new message to list
            if (result.data && messagesContainer) {
              if (emptyEl) emptyEl.hidden = true;
              messagesContainer.prepend(createMessageCard(result.data));
            }
          })
          .catch(function () {
            if (errorEl) {
              errorEl.textContent = 'Terjadi kesalahan. Coba lagi ya.';
              errorEl.hidden = false;
            }
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.textContent = '⭐ Kirim Ucapan';
            }
          });
      });
    }

    // Write again button
    if (writeAgainBtn && form && success) {
      writeAgainBtn.addEventListener('click', function () {
        success.hidden = true;
        form.hidden = false;
        form.style.opacity = '1';
        form.style.transform = 'scale(1)';
        form.reset();
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = '⭐ Kirim Ucapan';
        }
        if (errorEl) errorEl.hidden = true;
      });
    }
  })();
</script>

<style>
  .guestbook-section {
    padding-top: 4rem;
    padding-bottom: 5rem;
  }

  .section-heading {
    font-size: clamp(1.6rem, 5vw, 2.4rem);
    font-weight: 700;
    color: var(--color-dark);
    text-align: center;
    margin-bottom: 8px;
  }

  .section-sub {
    text-align: center;
    color: var(--color-muted);
    font-size: 1rem;
    margin-bottom: 2.5rem;
  }

  /* Purple clay card */
  .board-card {
    border-radius: 28px;
    overflow: hidden;
    margin-bottom: 2rem;
  }

  /* Header */
  .card-header {
    background: linear-gradient(135deg, #012A5E, #023E8A);
    padding: 18px 24px;
    display: flex;
    align-items: center;
    gap: 14px;
    box-shadow: inset 0 -3px 8px rgba(0,0,0,0.12);
  }

  .card-header-icon {
    font-size: 2rem;
    animation: float 3.5s ease-in-out infinite;
    display: inline-block;
  }

  .card-header-pre {
    font-size: 0.72rem;
    font-weight: 600;
    color: rgba(255,255,255,0.8);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .card-header-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #fff;
    text-shadow: 0 2px 4px rgba(0,0,0,0.2);
  }

  /* Form body */
  .card-body {
    background: linear-gradient(145deg, #fdf8ff 0%, #f5ecff 100%);
    padding: 28px 24px;
  }

  /* Form */
  .guestbook-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-label {
    font-size: 0.88rem;
    font-weight: 700;
    color: #7A4FA0;
    letter-spacing: 0.03em;
  }

  .form-input {
    font-family: var(--font-main);
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-dark);
    background: linear-gradient(145deg, #ffffff, #f9f4ff);
    border: 2.5px solid #0077B6;
    border-radius: 14px;
    padding: 12px 16px;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-shadow:
      inset 0 2px 6px rgba(201, 123, 255, 0.1),
      0 2px 8px rgba(0,0,0,0.04);
    resize: none;
    width: 100%;
  }

  .form-input::placeholder {
    color: #C4A8D8;
    font-weight: 400;
  }

  .form-input:focus {
    border-color: var(--color-purple);
    box-shadow:
      inset 0 2px 6px rgba(201, 123, 255, 0.15),
      0 0 0 3px rgba(201, 123, 255, 0.2);
  }

  .form-input:valid:not(:placeholder-shown) {
    border-color: var(--color-green);
  }

  .form-textarea {
    resize: vertical;
    min-height: 110px;
  }

  /* Submit button */
  .submit-btn {
    align-self: center;
    min-width: 200px;
    font-size: 1.05rem;
  }

  /* Success state */
  .success-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 20px 0;
    text-align: center;
  }

  .success-icon {
    font-size: 4rem;
    animation: bounce-in 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .success-title {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--color-purple);
  }

  .success-text {
    font-size: 1rem;
    color: var(--color-muted);
    max-width: 360px;
    line-height: 1.6;
  }

  .success-stars {
    font-size: 1.6rem;
    letter-spacing: 0.3em;
    animation: float 2.5s ease-in-out infinite;
    display: inline-block;
  }

  /* Blessing footer */
  .footer-blessing {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 1.5rem 0;
    border-top: 2px dashed rgba(0,0,0,0.08);
  }

  .footer-blessing p {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-dark);
  }

  .footer-parents {
    font-size: 1.2rem !important;
    font-weight: 700 !important;
    color: var(--color-purple) !important;
  }

  .footer-small {
    font-size: 0.85rem !important;
    font-weight: 400 !important;
    color: var(--color-muted) !important;
  }

  /* Error state */
  .form-error {
    background: #fff0f0;
    border: 2px solid #ff6b6b;
    border-radius: 12px;
    padding: 10px 16px;
    color: #d63031;
    font-size: 0.9rem;
    font-weight: 600;
    text-align: center;
  }

  /* Write again button */
  .write-again-btn {
    margin-top: 12px;
    font-size: 0.95rem;
  }

  /* Messages section */
  .messages-section {
    margin-top: 1.5rem;
    margin-bottom: 2rem;
  }

  .messages-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 1rem;
  }

  .messages-header-icon {
    font-size: 1.6rem;
  }

  .messages-header-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-dark);
  }

  .messages-loading,
  .messages-empty {
    text-align: center;
    padding: 2rem 1rem;
    color: var(--color-muted);
    font-size: 1rem;
  }

  .loading-spinner {
    display: inline-block;
    animation: float 2s ease-in-out infinite;
  }

  .messages-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-height: 400px;
    overflow-y: auto;
    padding-right: 4px;
  }

  .messages-list::-webkit-scrollbar {
    width: 6px;
  }

  .messages-list::-webkit-scrollbar-thumb {
    background: rgba(2, 62, 138, 0.2);
    border-radius: 3px;
  }

  .message-card {
    background: linear-gradient(145deg, #ffffff, #f5f0ff);
    border: 2px solid rgba(0, 119, 182, 0.15);
    border-radius: 18px;
    padding: 16px 18px;
    box-shadow:
      0 2px 8px rgba(0, 0, 0, 0.04),
      inset 0 1px 0 rgba(255, 255, 255, 0.8);
  }

  .message-card-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }

  .message-avatar {
    font-size: 1.4rem;
  }

  .message-name {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-purple);
  }

  .message-date {
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .message-text {
    font-size: 0.95rem;
    color: var(--color-dark);
    line-height: 1.6;
    white-space: pre-wrap;
    word-break: break-word;
  }

  @media (max-width: 480px) {
    .card-header, .card-body {
      padding-left: 18px;
      padding-right: 18px;
    }
  }
</style>
