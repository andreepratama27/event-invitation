---
---

<section class="section-wrapper guestbook-section">
  <div class="section-inner">
    <div class="section-label animate-on-scroll">GUESTBOOK · UCAPAN</div>

    <h2 class="section-heading animate-on-scroll">
      Tulis Ucapan Anda
    </h2>
    <p class="section-sub animate-on-scroll">
      Doa dan harapan Anda adalah hadiah terindah untuk Mateen 💜
    </p>

    <div class="board-card clay-purple animate-on-scroll">
      <!-- Card header -->
      <div class="card-header">
        <span class="card-header-icon">⭐</span>
        <div>
          <p class="card-header-pre">Buku Tamu</p>
          <p class="card-header-title">Kirim Ucapan & Doa</p>
        </div>
      </div>

      <!-- Form -->
      <div class="card-body">
        <form id="guestbook-form" class="guestbook-form" novalidate>
          <div class="form-group">
            <label class="form-label" for="guest-name">
              👤 Nama Kamu
            </label>
            <input
              id="guest-name"
              class="form-input"
              type="text"
              name="name"
              required
              minlength="2"
              placeholder="Tulis namamu di sini..."
              autocomplete="name"
            />
          </div>

          <div class="form-group">
            <label class="form-label" for="guest-message">
              💬 Ucapan & Doa
            </label>
            <textarea
              id="guest-message"
              class="form-input form-textarea"
              name="message"
              required
              minlength="5"
              rows="4"
              placeholder="Tuliskan doa dan harapan Anda untuk Emir Ayden Mateen..."
            ></textarea>
          </div>

          <div id="guestbook-error" class="form-error" hidden></div>

          <button type="submit" class="clay-btn clay-btn--green submit-btn" id="guestbook-submit-btn">
            ⭐ Kirim Ucapan
          </button>
        </form>

        <!-- Thank-you state (hidden initially) -->
        <div id="guestbook-success" class="success-state" hidden>
          <div class="success-icon">🎉</div>
          <h3 class="success-title">Terima kasih!</h3>
          <p class="success-text">Doa dan ucapanmu sudah kami terima. Semoga Allah SWT membalas kebaikanmu. 🤲</p>
          <div class="success-stars" aria-hidden="true">⭐ ⭐ ⭐</div>
          <button type="button" class="clay-btn clay-btn--green write-again-btn" id="guestbook-write-again">
            ✏️ Tulis Lagi
          </button>
        </div>
      </div>
    </div>

    <!-- Messages list -->
    <div class="messages-section clay-white animate-on-scroll">
      <div class="messages-header">
        <div class="messages-header-left">
          <span class="messages-header-icon">💌</span>
          <div>
            <h3 class="messages-header-title">Ucapan &amp; Doa</h3>
            <p class="messages-header-sub">dari Para Tamu</p>
          </div>
        </div>
        <div id="messages-count-badge" class="messages-count-badge" hidden>
          <span id="messages-count">0</span> ucapan
        </div>
      </div>

      <div id="guestbook-loading" class="messages-loading">
        <div class="loading-dots">
          <span></span><span></span><span></span>
        </div>
        <p>Memuat ucapan...</p>
      </div>

      <div id="guestbook-empty" class="messages-empty" hidden>
        <div class="empty-icon">🌟</div>
        <p>Belum ada ucapan.</p>
        <p class="empty-sub">Jadilah yang pertama kirim doa!</p>
      </div>

      <div id="guestbook-messages" class="messages-list"></div>

      <!-- Pagination -->
      <div id="guestbook-pagination" class="pagination" hidden>
        <button type="button" class="clay-btn clay-btn--purple pagination-btn" id="pagination-prev" disabled>
          ← Sebelumnya
        </button>
        <span class="pagination-info" id="pagination-info"></span>
        <button type="button" class="clay-btn clay-btn--purple pagination-btn" id="pagination-next">
          Selanjutnya →
        </button>
      </div>
    </div>

    <!-- Footer note -->
    <div class="footer-blessing animate-on-scroll">
      <p>Jazakumullahu Khairan Katsiran</p>
      <p class="footer-parents">Andre Pratama &amp; Syaras Saryang Putri</p>
      <p class="footer-small">beserta keluarga besar 🌙</p>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var form = document.getElementById('guestbook-form');
    var success = document.getElementById('guestbook-success');
    var errorEl = document.getElementById('guestbook-error');
    var submitBtn = document.getElementById('guestbook-submit-btn');
    var writeAgainBtn = document.getElementById('guestbook-write-again');
    var messagesContainer = document.getElementById('guestbook-messages');
    var loadingEl = document.getElementById('guestbook-loading');
    var emptyEl = document.getElementById('guestbook-empty');
    var paginationEl = document.getElementById('guestbook-pagination');
    var prevBtn = document.getElementById('pagination-prev');
    var nextBtn = document.getElementById('pagination-next');
    var pageInfoEl = document.getElementById('pagination-info');

    var PER_PAGE = 5;
    var allMessages = [];
    var currentPage = 0;

    function formatDate(dateStr) {
      var d = new Date(dateStr);
      return d.toLocaleDateString('id-ID', {
        day: 'numeric', month: 'long', year: 'numeric',
        hour: '2-digit', minute: '2-digit'
      });
    }

    function escapeHtml(str) {
      var div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    var CARD_ACCENTS = [
      { bar: '#FFB703', avatar: '#CC9200', deco: '⭐' },
      { bar: '#0096C7', avatar: '#006B8F', deco: '💙' },
      { bar: '#FB8500', avatar: '#C66A00', deco: '🎈' },
      { bar: '#023E8A', avatar: '#012A5E', deco: '🌙' },
      { bar: '#9B5DE5', avatar: '#6B3FA0', deco: '💜' }
    ];

    function hashAccent(str) {
      var h = 0;
      for (var i = 0; i < str.length; i++) h = (h * 31 + str.charCodeAt(i)) & 0xffff;
      return CARD_ACCENTS[h % CARD_ACCENTS.length];
    }

    function updateCountBadge(delta) {
      var badge = document.getElementById('messages-count-badge');
      var countEl = document.getElementById('messages-count');
      if (!badge || !countEl) return;
      var current = parseInt(countEl.textContent, 10) || 0;
      var next = delta === 'set' ? arguments[1] : current + delta;
      if (next > 0) {
        countEl.textContent = next;
        badge.hidden = false;
      } else {
        badge.hidden = true;
      }
    }

    function createMessageCard(entry, animate) {
      var accent = hashAccent(entry.name);
      var initial = entry.name.trim().charAt(0).toUpperCase();
      var card = document.createElement('div');
      card.className = 'message-card';
      card.style.setProperty('--bar', accent.bar);
      card.style.setProperty('--av', accent.avatar);
      card.innerHTML =
        '<div class="message-left-bar"></div>' +
        '<div class="message-body">' +
          '<div class="message-card-header">' +
            '<div class="message-avatar-circle">' + escapeHtml(initial) + '</div>' +
            '<div class="message-meta">' +
              '<p class="message-name">' + escapeHtml(entry.name) + '</p>' +
              '<p class="message-date">' + formatDate(entry.created_at) + '</p>' +
            '</div>' +
            '<span class="message-deco" aria-hidden="true">' + accent.deco + '</span>' +
          '</div>' +
          '<p class="message-text">' + escapeHtml(entry.message) + '</p>' +
        '</div>';

      if (animate) {
        card.style.opacity = '0';
        card.style.transform = 'translateY(-16px) scale(0.96)';
        card.style.transition = 'opacity 0.45s ease, transform 0.45s cubic-bezier(0.34, 1.56, 0.64, 1)';
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            card.style.opacity = '1';
            card.style.transform = 'translateY(0) scale(1)';
          });
        });
      }

      return card;
    }

    /* ---------- transition helpers ---------- */
    function fadeOut(el, duration, cb) {
      el.style.transition = 'opacity ' + duration + 'ms ease, transform ' + duration + 'ms ease';
      el.style.opacity = '0';
      el.style.transform = 'scale(0.95) translateY(6px)';
      setTimeout(function () {
        el.hidden = true;
        el.style.transition = '';
        el.style.transform = '';
        el.style.opacity = '';
        if (cb) cb();
      }, duration + 20);
    }

    function fadeIn(el, duration) {
      el.style.opacity = '0';
      el.style.transform = 'scale(0.92) translateY(10px)';
      el.style.transition = 'none';
      el.hidden = false;
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          el.style.transition =
            'opacity ' + duration + 'ms ease, ' +
            'transform ' + duration + 'ms cubic-bezier(0.34, 1.56, 0.64, 1)';
          el.style.opacity = '1';
          el.style.transform = 'scale(1) translateY(0)';
        });
      });
    }
    /* ---------------------------------------- */

    function renderPage(page) {
      currentPage = page;
      if (!messagesContainer) return;
      var totalPages = Math.ceil(allMessages.length / PER_PAGE);
      var start = page * PER_PAGE;
      var end = start + PER_PAGE;
      var pageItems = allMessages.slice(start, end);

      messagesContainer.innerHTML = '';
      pageItems.forEach(function (entry) {
        messagesContainer.appendChild(createMessageCard(entry, false));
      });

      if (paginationEl && totalPages > 1) {
        paginationEl.hidden = false;
        if (prevBtn) prevBtn.disabled = page === 0;
        if (nextBtn) nextBtn.disabled = page >= totalPages - 1;
        if (pageInfoEl) pageInfoEl.textContent = (page + 1) + ' / ' + totalPages;
      } else if (paginationEl) {
        paginationEl.hidden = true;
      }
    }

    function loadMessages() {
      fetch('/api/guestbook')
        .then(function (res) { return res.json(); })
        .then(function (result) {
          if (loadingEl) loadingEl.hidden = true;

          if (!result.ok || !result.data || result.data.length === 0) {
            if (emptyEl) emptyEl.hidden = false;
            return;
          }

          if (emptyEl) emptyEl.hidden = true;
          allMessages = result.data;
          updateCountBadge('set', allMessages.length);
          renderPage(0);
        })
        .catch(function () {
          if (loadingEl) loadingEl.hidden = true;
          if (emptyEl) emptyEl.hidden = false;
        });
    }

    // Pagination buttons
    if (prevBtn) {
      prevBtn.addEventListener('click', function () {
        if (currentPage > 0) renderPage(currentPage - 1);
      });
    }
    if (nextBtn) {
      nextBtn.addEventListener('click', function () {
        var totalPages = Math.ceil(allMessages.length / PER_PAGE);
        if (currentPage < totalPages - 1) renderPage(currentPage + 1);
      });
    }

    // Load messages on page load
    loadMessages();

    if (form && success) {
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        if (errorEl) errorEl.hidden = true;

        var nameEl = document.getElementById('guest-name');
        var msgEl = document.getElementById('guest-message');
        if (!nameEl || !msgEl) return;

        var name = nameEl.value.trim();
        var msg = msgEl.value.trim();

        if (!name || name.length < 2) { nameEl.focus(); return; }
        if (!msg || msg.length < 5) { msgEl.focus(); return; }

        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = '⏳ Mengirim...';
        }

        fetch('/api/guestbook', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name: name, message: msg })
        })
          .then(function (res) { return res.json(); })
          .then(function (result) {
            if (!result.ok) {
              if (errorEl) {
                errorEl.textContent = result.error || 'Gagal mengirim ucapan.';
                errorEl.hidden = false;
              }
              if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.textContent = '⭐ Kirim Ucapan';
              }
              return;
            }

            // Fade form out → fade success in
            fadeOut(form, 280, function () {
              fadeIn(success, 480);
            });

            // Prepend new message and re-render first page
            if (result.data) {
              if (emptyEl) emptyEl.hidden = true;
              allMessages.unshift(result.data);
              updateCountBadge('set', allMessages.length);
              renderPage(0);
            }
          })
          .catch(function () {
            if (errorEl) {
              errorEl.textContent = 'Terjadi kesalahan. Coba lagi ya.';
              errorEl.hidden = false;
            }
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.textContent = '⭐ Kirim Ucapan';
            }
          });
      });
    }

    // Write again button — smooth transition back to form
    if (writeAgainBtn && form && success) {
      writeAgainBtn.addEventListener('click', function () {
        fadeOut(success, 260, function () {
          form.reset();
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = '⭐ Kirim Ucapan';
          }
          if (errorEl) errorEl.hidden = true;
          fadeIn(form, 420);
        });
      });
    }
  })();
</script>

<style>
  .guestbook-section {
    padding-top: 4rem;
    padding-bottom: 5rem;
  }

  .section-heading {
    font-size: clamp(1.6rem, 5vw, 2.4rem);
    font-weight: 700;
    color: var(--color-dark);
    text-align: center;
    margin-bottom: 8px;
  }

  .section-sub {
    text-align: center;
    color: var(--color-muted);
    font-size: 1rem;
    margin-bottom: 2.5rem;
  }

  /* Purple clay card */
  .board-card {
    border-radius: 28px;
    overflow: hidden;
    margin-bottom: 2rem;
  }

  /* Header */
  .card-header {
    background: linear-gradient(135deg, #012A5E, #023E8A);
    padding: 18px 24px;
    display: flex;
    align-items: center;
    gap: 14px;
    box-shadow: inset 0 -3px 8px rgba(0,0,0,0.12);
  }

  .card-header-icon {
    font-size: 2rem;
    animation: float 3.5s ease-in-out infinite;
    display: inline-block;
  }

  .card-header-pre {
    font-size: 0.72rem;
    font-weight: 600;
    color: rgba(255,255,255,0.8);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .card-header-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #fff;
    text-shadow: 0 2px 4px rgba(0,0,0,0.2);
  }

  /* Form body */
  .card-body {
    background: linear-gradient(145deg, #fdf8ff 0%, #f5ecff 100%);
    padding: 28px 24px;
  }

  /* Form */
  .guestbook-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-label {
    font-size: 0.88rem;
    font-weight: 700;
    color: #7A4FA0;
    letter-spacing: 0.03em;
  }

  .form-input {
    font-family: var(--font-main);
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-dark);
    background: linear-gradient(145deg, #ffffff, #f9f4ff);
    border: 2.5px solid #0077B6;
    border-radius: 14px;
    padding: 12px 16px;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-shadow:
      inset 0 2px 6px rgba(201, 123, 255, 0.1),
      0 2px 8px rgba(0,0,0,0.04);
    resize: none;
    width: 100%;
  }

  .form-input::placeholder {
    color: #C4A8D8;
    font-weight: 400;
  }

  .form-input:focus {
    border-color: var(--color-purple);
    box-shadow:
      inset 0 2px 6px rgba(201, 123, 255, 0.15),
      0 0 0 3px rgba(201, 123, 255, 0.2);
  }

  .form-input:valid:not(:placeholder-shown) {
    border-color: var(--color-green);
  }

  .form-textarea {
    resize: vertical;
    min-height: 110px;
  }

  /* Submit button */
  .submit-btn {
    align-self: center;
    min-width: 200px;
    font-size: 1.05rem;
  }

  /* Success state */
  .success-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 20px 0;
    text-align: center;
    will-change: opacity, transform;
  }

  .success-icon {
    font-size: 4rem;
    animation: bounce-in 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .success-title {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--color-purple);
  }

  .success-text {
    font-size: 1rem;
    color: var(--color-muted);
    max-width: 360px;
    line-height: 1.6;
  }

  .success-stars {
    font-size: 1.6rem;
    letter-spacing: 0.3em;
    animation: float 2.5s ease-in-out infinite;
    display: inline-block;
  }

  /* Blessing footer */
  .footer-blessing {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 1.5rem 0;
    border-top: 2px dashed rgba(0,0,0,0.08);
  }

  .footer-blessing p {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-dark);
  }

  .footer-parents {
    font-size: 1.2rem !important;
    font-weight: 700 !important;
    color: var(--color-purple) !important;
  }

  .footer-small {
    font-size: 0.85rem !important;
    font-weight: 400 !important;
    color: var(--color-muted) !important;
  }

  /* Error state */
  .form-error {
    background: #fff0f0;
    border: 2px solid #ff6b6b;
    border-radius: 12px;
    padding: 10px 16px;
    color: #d63031;
    font-size: 0.9rem;
    font-weight: 600;
    text-align: center;
  }

  /* Write again button */
  .write-again-btn {
    margin-top: 12px;
    font-size: 0.95rem;
  }

  /* ── Messages section wrapper ── */
  .messages-section {
    margin-top: 1.5rem;
    margin-bottom: 2rem;
    border-radius: var(--radius-lg);
    padding: 22px 18px 24px;
    position: relative;
    overflow: hidden;
  }

  /* Dotted board texture */
  .messages-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(2, 62, 138, 0.07) 1.5px, transparent 1.5px);
    background-size: 22px 22px;
    pointer-events: none;
    z-index: 0;
  }

  .messages-header,
  .messages-loading,
  .messages-empty,
  .messages-list,
  .pagination {
    position: relative;
    z-index: 1;
  }

  /* ── Header ── */
  .messages-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 18px;
  }

  .messages-header-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .messages-header-icon {
    font-size: 2.2rem;
    animation: float 3.5s ease-in-out infinite;
    display: inline-block;
  }

  .messages-header-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-dark);
    line-height: 1.15;
  }

  .messages-header-sub {
    font-size: 0.73rem;
    color: var(--color-muted);
    font-weight: 500;
    margin-top: 1px;
  }

  /* Count badge */
  .messages-count-badge {
    background: linear-gradient(135deg, var(--color-purple-light), var(--color-purple));
    color: #fff;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 5px 13px;
    border-radius: 999px;
    box-shadow: 0 3px 0 var(--color-purple-dark), 0 4px 10px rgba(2,62,138,0.2);
    white-space: nowrap;
    flex-shrink: 0;
    letter-spacing: 0.02em;
  }

  /* ── Loading state ── */
  .messages-loading {
    text-align: center;
    padding: 2.5rem 1rem;
    color: var(--color-muted);
  }

  .messages-loading p {
    font-size: 0.9rem;
    margin-top: 10px;
  }

  .loading-dots {
    display: flex;
    justify-content: center;
    gap: 7px;
  }

  .loading-dots span {
    width: 9px;
    height: 9px;
    background: var(--color-purple-light);
    border-radius: 50%;
    animation: loading-bounce 1.3s ease-in-out infinite;
  }

  .loading-dots span:nth-child(2) { animation-delay: 0.2s; }
  .loading-dots span:nth-child(3) { animation-delay: 0.4s; }

  @keyframes loading-bounce {
    0%, 80%, 100% { transform: scale(0.55); opacity: 0.35; }
    40%            { transform: scale(1);    opacity: 1; }
  }

  /* ── Empty state ── */
  .messages-empty {
    text-align: center;
    padding: 2.5rem 1rem;
  }

  .empty-icon {
    font-size: 3rem;
    margin-bottom: 10px;
    animation: float 3s ease-in-out infinite;
    display: inline-block;
  }

  .messages-empty p {
    color: var(--color-dark);
    font-size: 1rem;
    font-weight: 600;
  }

  .empty-sub {
    color: var(--color-muted) !important;
    font-weight: 400 !important;
    font-size: 0.85rem !important;
    margin-top: 4px;
  }

  /* ── Messages list ── */
  .messages-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  /* Dynamic JS-generated elements need :global() to bypass Astro scoping */
  .messages-list :global(.message-card) {
    display: flex;
    background: linear-gradient(145deg, var(--color-green-light) 0%, var(--color-green) 100%);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow:
      0 6px 0 var(--color-green-dark),
      0 10px 20px rgba(0, 0, 0, 0.14),
      inset 0 -4px 8px rgba(0, 0, 0, 0.08),
      inset 0 4px 10px rgba(255, 255, 255, 0.45);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .messages-list :global(.message-card:active) {
    transform: translateY(4px);
    box-shadow:
      0 2px 0 var(--color-green-dark),
      0 4px 8px rgba(0, 0, 0, 0.12),
      inset 0 -2px 5px rgba(0, 0, 0, 0.08),
      inset 0 3px 7px rgba(255, 255, 255, 0.4);
  }

  .messages-list :global(.message-left-bar) {
    width: 6px;
    background: var(--bar, var(--color-purple));
    flex-shrink: 0;
    box-shadow: inset -2px 0 4px rgba(0, 0, 0, 0.15);
  }

  .messages-list :global(.message-body) {
    padding: 14px 16px 16px;
    flex: 1;
    min-width: 0;
  }

  .messages-list :global(.message-card-header) {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }

  .messages-list :global(.message-avatar-circle) {
    width: 38px;
    height: 38px;
